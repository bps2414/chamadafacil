# Supabase Project Settings > API > Project URL.
# Browser-safe value.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Project Settings > API > anon public key.
# Browser-safe value protected by RLS policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Project Settings > API > service_role key.
# Server-only. Required by constrained public ticket creation/lookup and rate limiting.
# Never expose this key in client code, screenshots, logs, or any NEXT_PUBLIC_ variable.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical public origin used by metadata, robots.txt, and sitemap.xml.
# Set this to the final production domain, without a trailing slash.
SITE_URL=https://chamadafacil.vercel.app
